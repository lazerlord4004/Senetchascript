-- TOGGLE: uses local bool, never reads toggleStates for logic
local function makeToggle(label, startVal, onChange, page)
    local on = startVal or false

    -- The button IS the row. Everything else is a child label/frame.
    -- No wrapper frame, no ZIndex games — just one TextButton.
    local btn = Instance.new("TextButton")
    btn.Name             = "Toggle_"..label
    btn.Size             = UDim2.new(1, 0, 0, 32)
    btn.BackgroundColor3 = on and C.bg3 or C.bg2
    btn.BorderSizePixel  = 0
    btn.Text             = ""
    btn.Font             = Enum.Font.Gotham
    btn.Parent           = page
    do local u = Instance.new("UICorner"); u.CornerRadius = UDim.new(0,7); u.Parent = btn end
    local rs = Instance.new("UIStroke"); rs.Color = on and C.borderOn or C.border; rs.Thickness = 1; rs.Parent = btn

    local lbl = Instance.new("TextLabel")
    lbl.Text             = label
    lbl.Size             = UDim2.new(1, -52, 1, 0)
    lbl.Position         = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3       = C.text
    lbl.TextSize         = 11
    lbl.Font             = Enum.Font.Gotham
    lbl.TextXAlignment   = Enum.TextXAlignment.Left
    lbl.Parent           = btn

    local track = Instance.new("Frame")
    track.Size             = UDim2.new(0, 28, 0, 14)
    track.Position         = UDim2.new(1, -36, 0.5, -7)
    track.BackgroundColor3 = on and C.accent or C.off
    track.BorderSizePixel  = 0
    track.Parent           = btn
    do local u = Instance.new("UICorner"); u.CornerRadius = UDim.new(0,7); u.Parent = track end

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 10, 0, 10)
    knob.Position         = on and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5)
    knob.BackgroundColor3 = on and C.textBright or Color3.fromRGB(170,165,190)
    knob.BorderSizePixel  = 0
    knob.Parent           = track
    do local u = Instance.new("UICorner"); u.CornerRadius = UDim.new(0,9); u.Parent = knob end

    activeToggles[label] = {on=on, dot=nil, lbl=nil}

    local function refresh()
        btn.BackgroundColor3   = on and C.bg3 or C.bg2
        rs.Color               = on and C.borderOn or C.border
        track.BackgroundColor3 = on and C.accent or C.off
        knob.Position          = on and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5)
        knob.BackgroundColor3  = on and C.textBright or Color3.fromRGB(170,165,190)
        if activeToggles[label] then activeToggles[label].on = on end
    end

    btn.MouseButton1Click:Connect(function()
        on = not on
        refresh()
        onChange(on)
    end)

    return function(val) on = val; refresh(); onChange(on) end
end


