local function makeSlider(label,minV,maxV,defV,suffix,onChange,page)
    suffix=suffix or ""
    local f=new("Frame",page,{Size=UDim2.new(1,0,0,48),BackgroundColor3=C.bg2,BorderSizePixel=0})
    corner(f,7); stroke(f,C.border,1)
    local cv=defV
    new("TextLabel",f,{Text=label,Size=UDim2.new(0.6,0,0,20),Position=UDim2.new(0,10,0,5),BackgroundTransparency=1,TextColor3=C.text,TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left})
    local vLbl=new("TextLabel",f,{Text=tostring(cv)..suffix,Size=UDim2.new(0.4,-10,0,20),Position=UDim2.new(0.6,0,0,5),BackgroundTransparency=1,TextColor3=C.accentBright,TextSize=11,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right})
    local track=new("Frame",f,{Size=UDim2.new(1,-20,0,4),Position=UDim2.new(0,10,0,32),BackgroundColor3=Color3.fromRGB(28,22,50),BorderSizePixel=0})
    corner(track,9)
    local fill=new("Frame",track,{Size=UDim2.new((defV-minV)/(maxV-minV),0,1,0),BackgroundColor3=C.accent,BorderSizePixel=0})
    corner(fill,9)
    local handle=new("Frame",track,{Size=UDim2.new(0,10,0,10),BackgroundColor3=C.textBright,BorderSizePixel=0})
    corner(handle,9)
    local function upd(r)
        cv=math.floor(minV+r*(maxV-minV)); fill.Size=UDim2.new(r,0,1,0)
        handle.Position=UDim2.new(r,-math.floor(10*r),0.5,-5)
        vLbl.Text=tostring(cv)..suffix; onChange(cv)
    end
    upd((defV-minV)/(maxV-minV))
    local drag=false
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    track.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    RunService.RenderStepped:Connect(function()
        if not drag then return end
        local r=math.clamp((UserInputService:GetMouseLocation().X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        upd(r)
    end)
end

