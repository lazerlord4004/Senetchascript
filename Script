local function switchTab(name)
    for _,n in ipairs(TAB_NAMES) do
        if tabPages[n] then tabPages[n].Visible=(n==name) end
        if tabBtns[n] then
            local isRage = (n=="Rage")
            local active = (n==name)
            tabBtns[n].BackgroundTransparency = active and 0 or 1
            tabBtns[n].BackgroundColor3 = active and (isRage and C.orange or C.accent) or Color3.fromRGB(0,0,0)
            tabBtns[n].TextColor3 = active and C.textBright or C.textDim
        end
    end
end

