-- Slider
local function makeSlider(name,icon,minVal,maxVal,defaultVal,callback,parent)
    parent=parent or scrollFrame
    local frame=Instance.new("Frame"); frame.Size=UDim2.new(1,0,0,50)
    frame.BackgroundColor3=Color3.fromRGB(25,20,45); frame.BorderSizePixel=0; frame.Parent=parent
    Instance.new("UICorner",frame).CornerRadius=UDim.new(0,7)
    local fS=Instance.new("UIStroke"); fS.Color=Color3.fromRGB(60,40,100); fS.Thickness=1; fS.Parent=frame
    local iL=Instance.new("TextLabel"); iL.Text=icon; iL.Size=UDim2.new(0,26,0,22); iL.Position=UDim2.new(0,6,0,4)
    iL.BackgroundTransparency=1; iL.TextColor3=Color3.fromRGB(200,160,255); iL.TextSize=14; iL.Font=Enum.Font.Gotham; iL.Parent=frame
    local cv=defaultVal
    local vL=Instance.new("TextLabel"); vL.Text=name..": "..tostring(cv); vL.Size=UDim2.new(1,-40,0,22); vL.Position=UDim2.new(0,34,0,4)
    vL.BackgroundTransparency=1; vL.TextColor3=Color3.fromRGB(220,220,240); vL.TextSize=11
    vL.Font=Enum.Font.Gotham; vL.TextXAlignment=Enum.TextXAlignment.Left; vL.Parent=frame
    local track=Instance.new("Frame"); track.Size=UDim2.new(1,-16,0,5); track.Position=UDim2.new(0,8,0,34)
    track.BackgroundColor3=Color3.fromRGB(50,40,80); track.BorderSizePixel=0; track.Parent=frame
    Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)
    local fill=Instance.new("Frame"); fill.Size=UDim2.new((defaultVal-minVal)/(maxVal-minVal),0,1,0)
    fill.BackgroundColor3=Color3.fromRGB(120,70,220); fill.BorderSizePixel=0; fill.Parent=track
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
    local drag=false
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    track.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    RunService.RenderStepped:Connect(function()
        if drag then
            local mp=UserInputService:GetMouseLocation()
            local ratio=math.clamp((mp.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
            cv=math.floor(minVal+ratio*(maxVal-minVal))
            fill.Size=UDim2.new(ratio,0,1,0); vL.Text=name..": "..tostring(cv); callback(cv)
        end
    end)
end

