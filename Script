local function makeSlider(name, icon, minV, maxV, defV, callback, parent)
    parent = parent or cheatsPage
    local frame = newInstance("Frame", {
        Size=UDim2.new(1,0,0,50), BackgroundColor3=Color3.fromRGB(22,18,44), BorderSizePixel=0}, parent)
    corner(frame, 7)
    stroke(frame, Color3.fromRGB(55,36,100), 1)

    newInstance("TextLabel", {Text=icon, Size=UDim2.new(0,26,0,22), Position=UDim2.new(0,6,0,4),
        BackgroundTransparency=1, TextColor3=Color3.fromRGB(200,160,255), TextSize=14, Font=Enum.Font.Gotham}, frame)

    local cv = defV
    local vLbl = newInstance("TextLabel", {
        Text=name..": "..cv, Size=UDim2.new(1,-40,0,22), Position=UDim2.new(0,34,0,4),
        BackgroundTransparency=1, TextColor3=Color3.fromRGB(215,215,235), TextSize=11,
        Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left}, frame)

    local track = newInstance("Frame", {
        Size=UDim2.new(1,-16,0,5), Position=UDim2.new(0,8,0,34),
        BackgroundColor3=Color3.fromRGB(46,38,78), BorderSizePixel=0}, frame)
    corner(track, 9)

    local fill = newInstance("Frame", {
        Size=UDim2.new((defV-minV)/(maxV-minV),0,1,0),
        BackgroundColor3=Color3.fromRGB(110,65,215), BorderSizePixel=0}, track)
    corner(fill, 9)

    local drag = false
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    track.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    RunService.RenderStepped:Connect(function()
        if not drag then return end
        local mp = UserInputService:GetMouseLocation()
        local r  = math.clamp((mp.X-track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
        cv = math.floor(minV + r*(maxV-minV))
        fill.Size = UDim2.new(r,0,1,0)
        vLbl.Text = name..": "..cv
        callback(cv)
    end)
end

