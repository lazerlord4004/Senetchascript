RunService.Heartbeat:Connect(function()
    if not triggerbotActive then return end
    local held=isKeyHeld(triggerKeybind)
    local jp=held and not triggerWasHeld

    if triggerbotSticky then
        if jp then triggerbotLocked=not triggerbotLocked end
        triggerWasHeld=held
        if not triggerbotLocked then return end
    else
        triggerWasHeld=held
        if not held then return end
    end

    if tick()-lastTriggerShot<TRIGGER_DELAY then return end
    local tool=character and character:FindFirstChildOfClass("Tool"); if not tool then return end
    local mp=UserInputService:GetMouseLocation()
    local ur=camera:ScreenPointToRay(mp.X,mp.Y)
    local rp=RaycastParams.new()
    rp.FilterDescendantsInstances={player.Character}
    rp.FilterType=Enum.RaycastFilterType.Exclude
    local res=workspace:Raycast(ur.Origin,ur.Direction*1000,rp)
    if not res then return end
    local hc=res.Instance:FindFirstAncestorOfClass("Model"); if not hc then return end
    local hp=Players:GetPlayerFromCharacter(hc); if not hp or hp==player then return end
    local hum=hc:FindFirstChildOfClass("Humanoid"); if not hum or hum.Health<=0 then return end
    pcall(function()
        VIM:SendMouseButtonEvent(mp.X,mp.Y,0,true, game,1)
        VIM:SendMouseButtonEvent(mp.X,mp.Y,0,false,game,1)
    end)
    lastTriggerShot=tick()
end)

