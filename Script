    local arrow=Instance.new("TextLabel"); arrow.Text="▶"; arrow.Size=UDim2.new(0,20,1,0); arrow.Position=UDim2.new(1,-26,0,0)
    arrow.BackgroundTransparency=1; arrow.TextColor3=Color3.fromRGB(160,120,240); arrow.TextSize=12
    arrow.Font=Enum.Font.GothamBold; arrow.Parent=header

    local inner=Instance.new("Frame"); inner.Size=UDim2.new(1,0,0,0); inner.BackgroundTransparency=1; inner.Parent=wrapper
    local iL=Instance.new("UIListLayout"); iL.Padding=UDim.new(0,4); iL.Parent=inner
    local iP=Instance.new("UIPadding"); iP.PaddingLeft=UDim.new(0,10); iP.PaddingBottom=UDim.new(0,4); iP.Parent=inner

    local function resize()
        local h=iL.AbsoluteContentSize.Y+8
        inner.Size=UDim2.new(1,0,0,isOpen and h or 0)
