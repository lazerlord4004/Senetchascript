-- ── Dropdown section ─────────────────────────────────────────────────────────
local function makeDropdown(name, icon, page)
    page = page or cheatsPage
    local isOpen = false

    -- Outer wrapper – height controlled manually
    local wrapper = newInstance("Frame", {
        Size                = UDim2.new(1, 0, 0, 36),
        BackgroundTransparency = 1,
        ClipsDescendants    = true,
    }, page)

    -- Stack children vertically inside wrapper
    local wLayout = newInstance("UIListLayout", {
        Padding   = UDim.new(0, 4),
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, wrapper)

    -- Header button
    local header = newInstance("TextButton", {
        Size             = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Color3.fromRGB(28, 20, 56),
        BorderSizePixel  = 0,
        Text             = "",
        LayoutOrder      = 0,
    }, wrapper)
    corner(header, 8)
    local hStroke = stroke(header, Color3.fromRGB(72, 46, 140), 1)

    newInstance("TextLabel", {
        Text              = icon,
        Size              = UDim2.new(0, 28, 1, 0),
        Position          = UDim2.new(0, 6, 0, 0),
        BackgroundTransparency = 1,
        TextColor3        = Color3.fromRGB(200, 160, 255),
        TextSize          = 15,
        Font              = Enum.Font.Gotham,
    }, header)

    newInstance("TextLabel", {
        Text              = name,
        Size              = UDim2.new(1, -60, 1, 0),
        Position          = UDim2.new(0, 36, 0, 0),
        BackgroundTransparency = 1,
        TextColor3        = Color3.fromRGB(225, 210, 255),
        TextSize          = 13,
        Font              = Enum.Font.GothamBold,
        TextXAlignment    = Enum.TextXAlignment.Left,
    }, header)

    local arrow = newInstance("TextLabel", {
        Text              = "▶",
        Size              = UDim2.new(0, 22, 1, 0),
        Position          = UDim2.new(1, -26, 0, 0),
        BackgroundTransparency = 1,
        TextColor3        = Color3.fromRGB(160, 120, 240),
        TextSize          = 12,
        Font              = Enum.Font.GothamBold,
    }, header)

    -- Inner container for child rows
    local inner = newInstance("Frame", {
        Size                = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        LayoutOrder         = 1,
    }, wrapper)
    local iLayout = newInstance("UIListLayout", {Padding=UDim.new(0,4), SortOrder=Enum.SortOrder.LayoutOrder}, inner)
    newInstance("UIPadding", {PaddingLeft=UDim.new(0,8), PaddingBottom=UDim.new(0,2)}, inner)

    local function resize()
        local contentH = iLayout.AbsoluteContentSize.Y + 6
        if isOpen then
            inner.Size   = UDim2.new(1, 0, 0, contentH)
            wrapper.Size = UDim2.new(1, 0, 0, 36 + 4 + contentH)
        else
            inner.Size   = UDim2.new(1, 0, 0, 0)
            wrapper.Size = UDim2.new(1, 0, 0, 36)
        end
    end
    iLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(resize)

    header.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        arrow.Text   = isOpen and "▼" or "▶"
        hStroke.Color = isOpen and Color3.fromRGB(110,65,210) or Color3.fromRGB(72,46,140)
        resize()
    end)

    return inner   -- caller parents their rows into `inner`
end

