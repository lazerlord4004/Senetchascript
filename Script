local kbCallback      = nil
local listeningForKey = false

local function openKeybindCapture(label, cb)
    kbSub.Text      = "for:  " .. label
    kbCallback      = cb
    kbGui.Enabled   = true
    listeningForKey = false
    -- task.wait() yields until next Heartbeat so the LMB click
    -- that opened the overlay is already fully processed and gone
    task.wait()
    listeningForKey = true
end

local function closeKeybindCapture()
    listeningForKey = false
    kbGui.Enabled   = false
    kbCallback      = nil
end

kbCancel.MouseButton1Click:Connect(closeKeybindCapture)

UserInputService.InputBegan:Connect(function(inp, gpe)
    if not listeningForKey then return end
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then return end
    if inp.KeyCode == Enum.KeyCode.Escape then closeKeybindCapture() return end

    local bindLabel, bindKey
    if inp.UserInputType == Enum.UserInputType.Keyboard then
        if inp.KeyCode == Enum.KeyCode.Unknown then return end
        bindLabel = inp.KeyCode.Name
        bindKey   = inp.KeyCode
    elseif inp.UserInputType == Enum.UserInputType.MouseButton2 then
        bindLabel = "RMB"
        bindKey   = Enum.UserInputType.MouseButton2
    else
        return
    end

    local savedCb = kbCallback
    closeKeybindCapture()
    if savedCb then savedCb(bindKey, bindLabel) end
end)

