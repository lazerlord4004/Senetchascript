local function installSilentHook()
    local mt=getrawmetatable(game); setreadonly(mt,false)
    local oi=mt.__index
    mt.__index=newcclosure(function(self,key)
        if silentAimActive and self==silentMouse and key=="Hit" then
            local closest,cd=nil,LEGIT_FOV
            for _,p in ipairs(Players:GetPlayers()) do
                if p~=player and p.Character then
                    local partName=aimBone=="Head" and "Head" or "HumanoidRootPart"
                    local part=p.Character:FindFirstChild(partName)
                    if part then
                        local pos,onScreen=camera:WorldToScreenPoint(part.Position)
                        if onScreen then
                            local dist=(Vector2.new(pos.X,pos.Y)-Vector2.new(silentMouse.X,silentMouse.Y)).Magnitude
                            if dist<cd then cd=dist; closest=p end
                        end
                    end
                end
            end
            local target=(silentAimSticky and silentAimLocked and silentAimTarget) or closest
            if target and target.Character then
                local pn=aimBone=="Head" and "Head" or "HumanoidRootPart"
                local part=target.Character:FindFirstChild(pn) or target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("HumanoidRootPart")
                if part then return part.CFrame+(part.Velocity*SILENT_PREDICTION) end
            end
        end
        return oi(self,key)
    end)
    setreadonly(mt,true)
end
pcall(installSilentHook)

