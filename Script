local function buildTabPage()
    local sf = newInstance("ScrollingFrame", {
        Size                  = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        ScrollBarThickness     = 3,
        ScrollBarImageColor3   = Color3.fromRGB(100, 60, 200),
        CanvasSize             = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize    = Enum.AutomaticSize.Y,
        Visible                = false,
    }, contentArea)
    newInstance("UIListLayout", {Padding = UDim.new(0, 5), SortOrder = Enum.SortOrder.LayoutOrder}, sf)
    newInstance("UIPadding", {
        PaddingLeft   = UDim.new(0, 2),
        PaddingRight  = UDim.new(0, 2),
        PaddingTop    = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 6),
    }, sf)
    return sf
end

local function switchTab(name)
    for _, n in ipairs(TAB_NAMES) do
        local active = (n == name)
        if tabPages[n]  then tabPages[n].Visible = active end
        if tabBtns[n]   then
            tabBtns[n].BackgroundColor3 = active
                and Color3.fromRGB(100, 55, 210)
                or  Color3.fromRGB(28, 22, 55)
            tabBtns[n].TextColor3 = active
                and Color3.fromRGB(255, 255, 255)
                or  Color3.fromRGB(160, 130, 210)
        end
    end
    activePage = tabPages[name]
end

for _, name in ipairs(TAB_NAMES) do
    tabPages[name] = buildTabPage()

    local tb = newInstance("TextButton", {
        Text             = name,
        Size             = UDim2.new(0, 96, 0, 24),
        BackgroundColor3 = Color3.fromRGB(28, 22, 55),
