RunService.RenderStepped:Connect(function()
    if not silentAimActive then
        if silentAimTarget then silentAimTarget=nil; updateAllESPColors() end
        aimbotWasHeld=false; silentAimLocked=false; return
    end
    local held=isKeyHeld(silentAimKeybind); local jp=held and not aimbotWasHeld
    if silentAimSticky then
        if jp then
            if silentAimLocked then silentAimLocked=false; silentAimTarget=nil; updateAllESPColors()
            else silentAimTarget=getNearestEnemy(); silentAimLocked=silentAimTarget~=nil; updateAllESPColors() end
        end
        if silentAimLocked and not targetAlive(silentAimTarget) then
            silentAimTarget=nil; silentAimLocked=false; updateAllESPColors() end
    else
        if held then
            local t=getNearestEnemy(); if t~=silentAimTarget then silentAimTarget=t; updateAllESPColors() end
        else
            if silentAimTarget then silentAimTarget=nil; updateAllESPColors() end
        end
    end
    aimbotWasHeld=held
end)

