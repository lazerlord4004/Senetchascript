local function removeESP(p)
    local o=ESP_OBJECTS[p]; if not o then return end
    for _,l in ipairs(o.box) do pcall(function() l:Remove() end) end
    for _,l in ipairs(o.bones) do pcall(function() l:Remove() end) end
    pcall(function() o.hpBg:Remove() end); pcall(function() o.hpFill:Remove() end)
    pcall(function() o.nameTag:Remove() end); pcall(function() o.tracer:Remove() end)
    ESP_OBJECTS[p]=nil
end

local function updateESPColors()
    for p,o in pairs(ESP_OBJECTS) do
        local col=getESPCol(p)
        for _,l in ipairs(o.box) do l.Color=col end
        o.nameTag.Color=col; o.tracer.Color=col
        for _,l in ipairs(o.bones) do l.Color=col end
    end
end

