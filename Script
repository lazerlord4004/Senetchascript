end

-- Project a 3D world point to 2D screen, returns x,y,visible
local function worldToScreen(pos)
    local sp,vis=camera:WorldToViewportPoint(pos)
    return sp.X,sp.Y,vis
end

-- ESP render loop
RunService.RenderStepped:Connect(function()
    for p,o in pairs(ESP_OBJECTS) do
        local char=p.Character
        local hrp=char and char:FindFirstChild("HumanoidRootPart")
        local hum=char and char:FindFirstChildOfClass("Humanoid")

        local alive = hrp~=nil and hum~=nil and hum.Health>0

        local function hideAll()
            for _,l in ipairs(o.box) do l.Visible=false end
            o.hpBg.Visible=false; o.hpFill.Visible=false; o.nameTag.Visible=false
        end

        if not alive then hideAll(); continue end

        -- ── Box ──────────────────────────────────────────────────
        -- Project head top and foot bottom to get screen height,
        -- then build a FIXED-WIDTH box from that height so it always
        -- looks square regardless of camera angle.
        local head=char:FindFirstChild("Head")
        local hPos = head and head.Position or hrp.Position+Vector3.new(0,1.5,0)
        local fPos = hrp.Position - Vector3.new(0,3,0)

        local hx,hy,hv = worldToScreen(hPos+Vector3.new(0,0.4,0))
        local fx,fy,fv = worldToScreen(fPos)

        if not (hv and fv) then hideAll(); continue end

        -- Screen-space box derived purely from projected head/foot
        local boxH = math.abs(fy-hy)
        local boxW = boxH * 0.55   -- fixed aspect ratio -> always looks like a box
        local cx   = (hx+fx)*0.5
        local top  = math.min(hy,fy)
        local bot  = math.max(hy,fy)
        local lft  = cx - boxW*0.5
        local rgt  = cx + boxW*0.5

        local col  = getESPColor(p)
        local show = espBoxOn and espActive
        local tl,tr,bl,br = Vector2.new(lft,top),Vector2.new(rgt,top),
                             Vector2.new(lft,bot), Vector2.new(rgt,bot)

        o.box[1].From=tl; o.box[1].To=tr; o.box[1].Color=col; o.box[1].Visible=show
        o.box[2].From=bl; o.box[2].To=br; o.box[2].Color=col; o.box[2].Visible=show
        o.box[3].From=tl; o.box[3].To=bl; o.box[3].Color=col; o.box[3].Visible=show
        o.box[4].From=tr; o.box[4].To=br; o.box[4].Color=col; o.box[4].Visible=show

        -- ── Health bar (left of box, same height) ─────────────────
        local hpShow = espHealthOn and espActive
        local ratio  = math.clamp(hum.Health/math.max(1,hum.MaxHealth),0,1)
        local hpX    = lft - 5
        local hpTop  = Vector2.new(hpX, top)
        local hpBot  = Vector2.new(hpX, bot)
        local hpMid  = Vector2.new(hpX, top + boxH*(1-ratio))
        local hpCol  = Color3.fromRGB(math.floor(220*(1-ratio)),math.floor(220*ratio),40)

        o.hpBg.From=hpTop;  o.hpBg.To=hpBot;   o.hpBg.Visible=hpShow
        o.hpFill.From=hpMid; o.hpFill.To=hpBot; o.hpFill.Visible=hpShow; o.hpFill.Color=hpCol

        -- ── Name (above box) ─────────────────────────────────────
        o.nameTag.Visible   = espNameOn and espActive
        o.nameTag.Position  = Vector2.new(cx, top-16)
        o.nameTag.Color     = col
    end
end)

