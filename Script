            end
        end
        if rageAimLocked then
            if not targetAlive(rageAimTarget) then
                rageAimTarget=nil; rageAimLocked=false; updateAllESPColors()
            else
                local aimPos=getAimPosition(rageAimTarget)
                if aimPos then
                    -- Hard lock: directly set camera direction, zero lag
                    local cf=camera.CFrame
                    camera.CFrame=CFrame.new(cf.Position,aimPos)
                end
            end
        end
    else
        if held then
            local t=getNearestInFov(math.huge)
            if t~=rageAimTarget then rageAimTarget=t; updateAllESPColors() end
            if rageAimTarget then
                if not targetAlive(rageAimTarget) then
                    rageAimTarget=nil; updateAllESPColors()
                else
                    local aimPos=getAimPosition(rageAimTarget)
