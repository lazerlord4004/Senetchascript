    local unitRay=camera:ScreenPointToRay(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    local rp=RaycastParams.new(); rp.FilterDescendantsInstances={player.Character}; rp.FilterType=Enum.RaycastFilterType.Exclude
    local result=workspace:Raycast(unitRay.Origin, unitRay.Direction*500, rp)
