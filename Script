-- ============================================================
local function stopOrbit()
    orbitOn=false
    if orbitBV then orbitBV:Destroy();orbitBV=nil end
    if orbitBG then orbitBG:Destroy();orbitBG=nil end
end
local function startOrbit(target)
    stopOrbit(); if not target or not target.Character then return end
    orbitTarget=target; orbitOn=true; orbitAngle=0
    local hrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    orbitBV=Instance.new("BodyVelocity"); orbitBV.Velocity=Vector3.zero; orbitBV.MaxForce=Vector3.new(1e5,1e5,1e5); orbitBV.Parent=hrp
    orbitBG=Instance.new("BodyGyro"); orbitBG.MaxTorque=Vector3.new(1e5,1e5,1e5); orbitBG.P=1e4; orbitBG.Parent=hrp
end
RunService.RenderStepped:Connect(function(dt)
    if not orbitOn then return end
    if not orbitTarget or not orbitTarget.Character then stopOrbit(); return end
    local tHrp=orbitTarget.Character:FindFirstChild("HumanoidRootPart")
    local mHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not tHrp or not mHrp or not orbitBV then stopOrbit(); return end
    orbitAngle=orbitAngle+orbitSpeed*dt
    local op=tHrp.Position+Vector3.new(math.cos(orbitAngle)*orbitRadius,orbitHeight,math.sin(orbitAngle)*orbitRadius)
    orbitBV.Velocity=(op-mHrp.Position)*8
    if orbitBG then orbitBG.CFrame=CFrame.new(mHrp.Position,tHrp.Position) end
    camera.CFrame=CFrame.new(mHrp.Position,tHrp.Position)
end)

