local function isKeyHeld(bind)
    if typeof(bind)~="EnumItem" then return false end
    if bind.EnumType==Enum.KeyCode then return UserInputService:IsKeyDown(bind)
    elseif bind.EnumType==Enum.UserInputType then return UserInputService:IsMouseButtonPressed(bind) end
    return false
end

local function getAimPos(p)
    if not p or not p.Character then return nil end
    if aimBone=="Head" then local h=p.Character:FindFirstChild("Head"); return h and h.Position or nil
    else local t=p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso") or p.Character:FindFirstChild("HumanoidRootPart"); return t and t.Position or nil end
end

local function alive(p)
    if not p or not p.Character then return false end
    local hum=p.Character:FindFirstChildOfClass("Humanoid"); return hum~=nil and hum.Health>0
end

local function getNearestInFov(fovPx)
    local mp=UserInputService:GetMouseLocation(); local best,bestD=nil,fovPx
    for _,p in pairs(Players:GetPlayers()) do
        if p~=player and p.Character then
            local hum=p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health>0 then
                local hrp=p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local parts={hrp}
                    local h=p.Character:FindFirstChild("Head"); if h then parts[#parts+1]=h end
                    local t=p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso"); if t then parts[#parts+1]=t end
                    local d=math.huge
                    for _,part in ipairs(parts) do local sx,sy,vis=wts(part.Position); if vis then d=math.min(d,(Vector2.new(sx,sy)-mp).Magnitude) end end
                    if d<bestD then bestD=d; best=p end
                end
            end
        end
    end
    return best
end

