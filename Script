    local specBtn=actionBtn("Spectate",Color3.fromRGB(50,110,200),-200)
    local tpBtn  =actionBtn("Teleport",Color3.fromRGB(40,140,80), -138)
    local flBtn  =actionBtn("Fling",   Color3.fromRGB(190,50,60), -76)

    specBtn.Name="SpecBtn"
    specBtn.MouseButton1Click:Connect(function()
        if spectating==target then
            stopSpectate(); specBtn.Text="Spectate"; specBtn.BackgroundColor3=Color3.fromRGB(50,110,200)
        else
            startSpectate(target); specBtn.Text="■ Stop"; specBtn.BackgroundColor3=Color3.fromRGB(120,60,20)
            for p,r in pairs(plRows) do
                if p~=target then local sb=r:FindFirstChild("SpecBtn"); if sb then sb.Text="Spectate"; sb.BackgroundColor3=Color3.fromRGB(50,110,200) end end
            end
        end
    end)
    tpBtn.MouseButton1Click:Connect(function() teleportToPlayer(target) end)
    flBtn.MouseButton1Click:Connect(function() flingPlayer(target) end)

    plRows[target]=row
end

local function removePlayerRow(target)
    if plRows[target] then plRows[target]:Destroy(); plRows[target]=nil end
end

for _,p in pairs(Players:GetPlayers()) do if p~=player then buildPlayerRow(p) end end
Players.PlayerAdded:Connect(function(p) task.wait(0.5); buildPlayerRow(p) end)
Players.PlayerRemoving:Connect(function(p)
    if spectating==p then stopSpectate() end
    removePlayerRow(p)
end)

