-- Slider
local function makeSlider(name, minV, maxV, defV, suffix, cb, parent)
    parent = parent or cheatsPage
    suffix = suffix or ""
    local frame = make("Frame",{
        Size=UDim2.new(1,0,0,48),
        BackgroundColor3=C.bg2, BorderSizePixel=0,
    },parent)
    corner(frame,7)
    uistroke(frame,C.border,1)

    local cv = defV
    local vLbl = make("TextLabel",{
        Text=name..":  "..cv..suffix,
        Size=UDim2.new(1,-16,0,20), Position=UDim2.new(0,8,0,4),
        BackgroundTransparency=1, TextColor3=C.text,
        TextSize=11, Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Left,
    },frame)

    local track = make("Frame",{
        Size=UDim2.new(1,-16,0,4), Position=UDim2.new(0,8,0,30),
        BackgroundColor3=C.bg3, BorderSizePixel=0,
    },frame)
    corner(track,9)

    local fill = make("Frame",{
        Size=UDim2.new((defV-minV)/(maxV-minV),0,1,0),
        BackgroundColor3=C.accent, BorderSizePixel=0,
    },track)
    corner(fill,9)

    local drag=false
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    track.InputEnded:Connect(function(i)  if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    RunService.RenderStepped:Connect(function()
        if not drag then return end
        local mp=UserInputService:GetMouseLocation()
        local r=math.clamp((mp.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        cv=math.floor(minV+r*(maxV-minV))
        fill.Size=UDim2.new(r,0,1,0)
        vLbl.Text=name..":  "..cv..suffix
        cb(cv)
    end)
    return frame
end

