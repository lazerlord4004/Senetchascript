-- ================================================================
--  ORBIT  (fly above selected player, circle them)
-- ================================================================
local function stopOrbit()
    orbitActive=false
    if orbitBV then orbitBV:Destroy(); orbitBV=nil end
    if orbitBG then orbitBG:Destroy(); orbitBG=nil end
end

local function startOrbit(target)
    stopOrbit()
    if not target or not target.Character then return end
    orbitTarget=target
    orbitActive=true
    orbitAngle=0

    local hrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    orbitBV=Instance.new("BodyVelocity")
    orbitBV.Velocity=Vector3.zero
    orbitBV.MaxForce=Vector3.new(1e5,1e5,1e5)
    orbitBV.Parent=hrp

    orbitBG=Instance.new("BodyGyro")
    orbitBG.MaxTorque=Vector3.new(1e5,1e5,1e5)
    orbitBG.P=1e4
    orbitBG.Parent=hrp
end

RunService.RenderStepped:Connect(function(dt)
    if not orbitActive then return end
    if not orbitTarget or not orbitTarget.Character then stopOrbit(); return end
    local tHrp=orbitTarget.Character:FindFirstChild("HumanoidRootPart")
    local mHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not tHrp or not mHrp or not orbitBV or not orbitBG then stopOrbit(); return end

    orbitAngle=orbitAngle+orbitSpeed*dt

    local targetPos=tHrp.Position
    local orbitPos=targetPos + Vector3.new(
        math.cos(orbitAngle)*orbitRadius,
        orbitHeight,
        math.sin(orbitAngle)*orbitRadius
    )

    -- Move toward orbit position
    local diff=orbitPos-mHrp.Position
    orbitBV.Velocity=diff*8   -- spring-like follow, smooth but responsive

    -- Always face the target
    orbitBG.CFrame=CFrame.new(mHrp.Position,targetPos)

    -- Lock camera to look at target too
    camera.CFrame=CFrame.new(mHrp.Position,targetPos)
end)

-- ================================================================
--  SILENT AIM  (polls LMB each frame, no gpe issue)
-- ================================================================
RunService.RenderStepped:Connect(function()
    -- Redirect happens first, before target selection logic
    if silentAimActive and silentAimTarget then
        local lmbDown=UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
        local justClicked=lmbDown and not silentLmbWasDown
        if justClicked then
            local tool=character and character:FindFirstChildOfClass("Tool")
            if tool then
                local aimPos=getAimPosition(silentAimTarget)
                if aimPos then
                    local savedCF=camera.CFrame
                    camera.CFrame=CFrame.new(savedCF.Position,aimPos)
                    -- Restore next frame — task.defer runs before next render
                    task.defer(function() camera.CFrame=savedCF end)
                end
            end
        end
        silentLmbWasDown=lmbDown
    else
        silentLmbWasDown=false
    end

    -- Target selection
    if not silentAimActive then
        if silentAimTarget then silentAimTarget=nil; updateAllESPColors() end
        silentWasHeld=false; silentAimLocked=false; return
    end
    local held=isKeyHeld(silentKeybind)
    local jp=held and not silentWasHeld
    if silentAimSticky then
        if jp then
            if silentAimLocked then
                silentAimLocked=false; silentAimTarget=nil; updateAllESPColors()
            else
                silentAimTarget=getNearestInFov(LEGIT_FOV)
                silentAimLocked=silentAimTarget~=nil; updateAllESPColors()
            end
        end
        if silentAimLocked and not targetAlive(silentAimTarget) then
            silentAimTarget=nil; silentAimLocked=false; updateAllESPColors()
        end
    else
        if held then
            local t=getNearestInFov(LEGIT_FOV)
            if t~=silentAimTarget then silentAimTarget=t; updateAllESPColors() end
        else
            if silentAimTarget then silentAimTarget=nil; updateAllESPColors() end
        end
    end
    silentWasHeld=held
end)

