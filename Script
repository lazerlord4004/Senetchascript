    end)
    orBtn.MouseButton1Click:Connect(function()
        if orbitOn and orbitTarget==target then stopOrbit(); orBtn.Text="Orbit"; orBtn.BackgroundColor3=Color3.fromRGB(75,45,155)
        else orbitTarget=target; startOrbit(target); orBtn.Text="Stop"; orBtn.BackgroundColor3=C.red
            for p2,r2 in pairs(plRows) do if p2~=target then local b=r2:FindFirstChild("OrBtn"); if b then b.Text="Orbit"; b.BackgroundColor3=Color3.fromRGB(75,45,155) end end end end
    end)
    spBtn.MouseButton1Click:Connect(function()
        if spectating==target then stopSpec(); spBtn.Text="Spectate"; spBtn.BackgroundColor3=Color3.fromRGB(40,95,175)
        else startSpec(target); spBtn.Text="Stop"; spBtn.BackgroundColor3=Color3.fromRGB(105,50,14)
            for p2,r2 in pairs(plRows) do if p2~=target then local b=r2:FindFirstChild("SpBtn"); if b then b.Text="Spectate"; b.BackgroundColor3=Color3.fromRGB(40,95,175) end end end end
    end)
    tpBtn.MouseButton1Click:Connect(function() tp(target) end)
    flBtn.MouseButton1Click:Connect(function() fling(target) end)
    cpBtn.MouseButton1Click:Connect(function() pcall(function() setclipboard(target.Name) end); cpBtn.Text="Copied!"; task.delay(1.5,function() cpBtn.Text="Copy" end) end)
    plRows[target]=row
end
