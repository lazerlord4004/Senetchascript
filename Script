local function getESPColor(p)
    local locked=(legitAimActive and legitAimTarget==p)
               or(rageAimActive and rageAimTarget==p)
               or(silentAimActive and silentAimTarget==p)
    return locked and Color3.fromRGB(220,40,40) or Color3.fromRGB(255,255,255)
end

local function newLine(thick,col,zi)
    local l=Drawing.new("Line"); l.Visible=false; l.Color=col or Color3.new(1,1,1)
    l.Thickness=thick or 1.5; l.Transparency=1; l.ZIndex=zi or 5; return l
end
local function newText2()
    local t=Drawing.new("Text"); t.Visible=false; t.Color=Color3.new(1,1,1)
    t.Size=13; t.Font=Drawing.Fonts.UI; t.Outline=true
    t.OutlineColor=Color3.new(0,0,0); t.Center=true; t.ZIndex=6; return t
end

local function worldToScreen(pos)
    local sp,vis=camera:WorldToViewportPoint(pos); return sp.X,sp.Y,vis
end

local function createESP(p)
    if not p.Character or ESP_OBJECTS[p] then return end
    local hrp=p.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local box={newLine(1.5),newLine(1.5),newLine(1.5),newLine(1.5)}
    local hpBg=newLine(4,Color3.fromRGB(25,20,40),4)
    local hpFill=newLine(3,Color3.fromRGB(60,220,90),5)
    local nameTag=newText2(); nameTag.Text=p.Name
    ESP_OBJECTS[p]={box=box,hpBg=hpBg,hpFill=hpFill,nameTag=nameTag}
end

local function removeESP(p)
    local o=ESP_OBJECTS[p]; if not o then return end
    for _,l in ipairs(o.box) do pcall(function() l:Remove() end) end
    pcall(function() o.hpBg:Remove() end)
    pcall(function() o.hpFill:Remove() end)
    pcall(function() o.nameTag:Remove() end)
    ESP_OBJECTS[p]=nil
end

local function updateAllESPColors()
    for p,o in pairs(ESP_OBJECTS) do
        local col=getESPColor(p)
        for _,l in ipairs(o.box) do l.Color=col end
        o.nameTag.Color=col
    end
end

local function enableESP()
    for _,p in pairs(Players:GetPlayers()) do if p~=player then createESP(p) end end
end
local function disableESP()
    for p in pairs(ESP_OBJECTS) do removeESP(p) end
end

RunService.RenderStepped:Connect(function()
    for p,o in pairs(ESP_OBJECTS) do
        local char=p.Character
        local hrp=char and char:FindFirstChild("HumanoidRootPart")
        local hum=char and char:FindFirstChildOfClass("Humanoid")
        local alive=hrp~=nil and hum~=nil and hum.Health>0
        local function hideAll()
            for _,l in ipairs(o.box) do l.Visible=false end
            o.hpBg.Visible=false; o.hpFill.Visible=false; o.nameTag.Visible=false
        end
        if not alive then hideAll(); continue end
        local head=char:FindFirstChild("Head")
        local hPos=head and head.Position or hrp.Position+Vector3.new(0,1.5,0)
        local fPos=hrp.Position-Vector3.new(0,3,0)
        local hx,hy,hv=worldToScreen(hPos+Vector3.new(0,0.4,0))
        local fx,fy,fv=worldToScreen(fPos)
        if not(hv and fv) then hideAll(); continue end
        local boxH=math.abs(fy-hy)
        local boxW=boxH*0.55
        local cx=(hx+fx)*0.5
        local top=math.min(hy,fy); local bot=math.max(hy,fy)
        local lft=cx-boxW*0.5;    local rgt=cx+boxW*0.5
        local col=getESPColor(p)
        local show=espBoxOn and espActive
        local tl,tr=Vector2.new(lft,top),Vector2.new(rgt,top)
        local bl,br=Vector2.new(lft,bot), Vector2.new(rgt,bot)
        o.box[1].From=tl;o.box[1].To=tr;o.box[1].Color=col;o.box[1].Visible=show
        o.box[2].From=bl;o.box[2].To=br;o.box[2].Color=col;o.box[2].Visible=show
        o.box[3].From=tl;o.box[3].To=bl;o.box[3].Color=col;o.box[3].Visible=show
        o.box[4].From=tr;o.box[4].To=br;o.box[4].Color=col;o.box[4].Visible=show
        local hpShow=espHealthOn and espActive
        local ratio=math.clamp(hum.Health/math.max(1,hum.MaxHealth),0,1)
        local hpX=lft-5
        local hpTop=Vector2.new(hpX,top); local hpBot=Vector2.new(hpX,bot)
        local hpMid=Vector2.new(hpX,top+boxH*(1-ratio))
        local hpCol=Color3.fromRGB(math.floor(220*(1-ratio)),math.floor(220*ratio),40)
        o.hpBg.From=hpTop;o.hpBg.To=hpBot;o.hpBg.Visible=hpShow
        o.hpFill.From=hpMid;o.hpFill.To=hpBot;o.hpFill.Visible=hpShow;o.hpFill.Color=hpCol
        o.nameTag.Visible=espNameOn and espActive
        o.nameTag.Position=Vector2.new(cx,top-16); o.nameTag.Color=col
    end
end)

