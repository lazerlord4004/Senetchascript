end)

-- ============================================================
--  AIMBOT  (hold OR toggle mode)
-- ============================================================
RunService.RenderStepped:Connect(function()
    if not aimbotActive then
        if aimbotTarget then aimbotTarget=nil; updateAllESPColors() end
        aimbotWasHeld=false; aimbotLocked=false; return
    end
    local held=isKeyHeld(aimbotKeybind)
    local jp=held and not aimbotWasHeld   -- "just pressed" edge

    if aimbotSticky then
        -- TOGGLE mode: press once to lock, again to release
        if jp then
            if aimbotLocked then
                aimbotLocked=false; aimbotTarget=nil; updateAllESPColors()
            else
                aimbotTarget=getNearestEnemy()
                aimbotLocked=aimbotTarget~=nil
                updateAllESPColors()
            end
        end
        if aimbotLocked then
            if not targetAlive(aimbotTarget) then
                aimbotTarget=nil; aimbotLocked=false; updateAllESPColors()
            else
                local hw=getHeadWorld(aimbotTarget)
                if hw then
                    local cf=camera.CFrame
                    camera.CFrame=cf:Lerp(CFrame.lookAt(cf.Position,hw),AIMBOT_SMOOTHING)
                end
            end
        end
    else
        -- HOLD mode
        if held then
            local t=getNearestEnemy()
            if t~=aimbotTarget then aimbotTarget=t; updateAllESPColors() end
            if aimbotTarget then
                local hw=getHeadWorld(aimbotTarget)
                if hw then
                    local cf=camera.CFrame
                    camera.CFrame=cf:Lerp(CFrame.lookAt(cf.Position,hw),AIMBOT_SMOOTHING)
                end
            end
        else
            if aimbotTarget then aimbotTarget=nil; updateAllESPColors() end
        end
    end
    aimbotWasHeld=held
end)

