RunService.RenderStepped:Connect(function()
    if not legitAimActive then
        if legitAimTarget then legitAimTarget=nil; updateAllESPColors() end
        legitWasHeld=false; legitAimLocked=false; return
    end
    local held=isKeyHeld(legitKeybind)
    local jp=held and not legitWasHeld

    if legitAimSticky then
        if jp then
            if legitAimLocked then
                legitAimLocked=false; legitAimTarget=nil; updateAllESPColors()
            else
                legitAimTarget=getNearestInFov(LEGIT_FOV)
                legitAimLocked=legitAimTarget~=nil; updateAllESPColors()
            end
        end
        if legitAimLocked then
            if not targetAlive(legitAimTarget) then
                legitAimTarget=nil; legitAimLocked=false; updateAllESPColors()
            else
                local aimPos=getAimPosition(legitAimTarget)
                if aimPos then
                    local cf=camera.CFrame
                    -- Smooth lerp toward target — feels human, not instant
                    camera.CFrame=cf:Lerp(CFrame.new(cf.Position,aimPos),LEGIT_SMOOTH)
                end
            end
        end
    else
        if held then
            local t=getNearestInFov(LEGIT_FOV)
            if t~=legitAimTarget then legitAimTarget=t; updateAllESPColors() end
            if legitAimTarget then
                if not targetAlive(legitAimTarget) then
                    legitAimTarget=nil; updateAllESPColors()
                else
                    local aimPos=getAimPosition(legitAimTarget)
                    if aimPos then
                        local cf=camera.CFrame
                        camera.CFrame=cf:Lerp(CFrame.new(cf.Position,aimPos),LEGIT_SMOOTH)
                    end
                end
            end
        else
            if legitAimTarget then legitAimTarget=nil; updateAllESPColors() end
        end
    end
    legitWasHeld=held
end)

