local BONE_R15={{"Head","UpperTorso"},{"UpperTorso","LowerTorso"},{"LowerTorso","LeftUpperLeg"},{"LowerTorso","RightUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"RightUpperLeg","RightLowerLeg"},{"LeftLowerLeg","LeftFoot"},{"RightLowerLeg","RightFoot"},{"UpperTorso","LeftUpperArm"},{"UpperTorso","RightUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"RightUpperArm","RightLowerArm"},{"LeftLowerArm","LeftHand"},{"RightLowerArm","RightHand"}}
local BONE_R6={{"Head","Torso"},{"Torso","Left Arm"},{"Torso","Right Arm"},{"Torso","Left Leg"},{"Torso","Right Leg"}}
local function wts(p) local s,v=camera:WorldToViewportPoint(p); return s.X,s.Y,v end
local function getCol(p) return ((legitOn and legitTarget==p) or (rageOn and rageTarget==p) or (silentOn and silentTarget==p)) and Color3.fromRGB(220,40,40) or Color3.fromRGB(255,255,255) end
local function newLine(thick,col,zi) local l=Drawing.new("Line"); l.Visible=false; l.Color=col or Color3.new(1,1,1); l.Thickness=thick or 1.5; l.Transparency=1; l.ZIndex=zi or 5; return l end
local function newTxt() local t=Drawing.new("Text"); t.Visible=false; t.Color=Color3.new(1,1,1); t.Size=13; t.Font=Drawing.Fonts.Monospace; t.Outline=true; t.OutlineColor=Color3.new(0,0,0); t.Center=true; t.ZIndex=6; return t end

local function addESP(p)
    if not p.Character or ESP[p] then return end
    local hrp=p.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local isR15=p.Character:FindFirstChild("UpperTorso")~=nil
    local conns=isR15 and BONE_R15 or BONE_R6
    local bones={}; for i=1,#conns do bones[i]=newLine(1) end
    ESP[p]={box={newLine(1.5),newLine(1.5),newLine(1.5),newLine(1.5)},hpBg=newLine(4,Color3.fromRGB(20,16,36),4),hpFill=newLine(3,Color3.fromRGB(60,220,90),5),name=newTxt(),tracer=newLine(1,Color3.new(1,1,1),4),bones=bones,conns=conns}
    ESP[p].name.Text=p.Name
end
local function remESP(p)
    local o=ESP[p]; if not o then return end
    for _,l in ipairs(o.box) do pcall(function() l:Remove() end) end
    for _,l in ipairs(o.bones) do pcall(function() l:Remove() end) end
    pcall(function() o.hpBg:Remove() end); pcall(function() o.hpFill:Remove() end)
    pcall(function() o.name:Remove() end); pcall(function() o.tracer:Remove() end)
    ESP[p]=nil
end
local function enableESP() for _,p in pairs(Players:GetPlayers()) do if p~=player then addESP(p) end end end
local function disableESP() for p in pairs(ESP) do remESP(p) end end

