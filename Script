local function getESPColor(p)
    local isTarget = (aimbotActive and aimbotTarget==p) or (silentAimActive and silentAimTarget==p)
    if isTarget then return Color3.fromRGB(255,40,40), Color3.fromRGB(255,0,0), Color3.fromRGB(255,70,70) end
    return Color3.fromRGB(255,255,255), Color3.fromRGB(200,200,200), Color3.fromRGB(255,255,255)
end

local function createESP(p)
    if not p.Character or ESP_OBJECTS[p] then return end
    local hrp = p.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local hl  = newInstance("Highlight", {Name="SenetchaESP", FillTransparency=0.6, OutlineTransparency=0}, p.Character)
    local bb  = newInstance("BillboardGui", {
        Name="SenetchaESPBB", Size=UDim2.new(0,140,0,34),
        StudsOffset=Vector3.new(0,3.5,0), AlwaysOnTop=true}, hrp)
    local nL = newInstance("TextLabel", {
        Size=UDim2.new(1,0,0.6,0), BackgroundTransparency=1, Text=p.Name,
        TextColor3=Color3.fromRGB(255,255,255), TextSize=14, Font=Enum.Font.GothamBold,
        TextStrokeTransparency=0.3, TextStrokeColor3=Color3.fromRGB(0,0,0)}, bb)
    local hL = newInstance("TextLabel", {
        Size=UDim2.new(1,0,0.4,0), Position=UDim2.new(0,0,0.6,0),
        BackgroundTransparency=1, Text="HP: ?",
        TextColor3=Color3.fromRGB(100,255,120), TextSize=11, Font=Enum.Font.Gotham,
        TextStrokeTransparency=0.3, TextStrokeColor3=Color3.fromRGB(0,0,0)}, bb)
    ESP_OBJECTS[p] = {highlight=hl, billboard=bb, nameLabel=nL, hpLabel=hL}
    local fc,oc,tc = getESPColor(p); hl.FillColor=fc; hl.OutlineColor=oc; nL.TextColor3=tc
end

local function removeESP(p)
    if not ESP_OBJECTS[p] then return end
    pcall(function() ESP_OBJECTS[p].highlight:Destroy() end)
    pcall(function() ESP_OBJECTS[p].billboard:Destroy() end)
    ESP_OBJECTS[p] = nil
end

local function updateAllESPColors()
    for p, o in pairs(ESP_OBJECTS) do
        if o.highlight and o.highlight.Parent then
            local fc,oc,tc = getESPColor(p)
            o.highlight.FillColor=fc; o.highlight.OutlineColor=oc
            if o.nameLabel and o.nameLabel.Parent then o.nameLabel.TextColor3=tc end
        end
    end
end

local function enableESP()  for _,p in pairs(Players:GetPlayers()) do if p~=player then createESP(p) end end end
local function disableESP() for p in pairs(ESP_OBJECTS) do removeESP(p) end end

