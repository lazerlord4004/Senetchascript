    local hp=Players:GetPlayerFromCharacter(hc); if not hp or hp==player then return end
    local hum=hc:FindFirstChildOfClass("Humanoid"); if not hum or hum.Health<=0 then return end
    pcall(function() VIM:SendMouseButtonEvent(mp.X,mp.Y,0,true,game,1) end); trigPressed=true; lastShot=now
    task.delay(TRIG_REL,function() local mp2=UserInputService:GetMouseLocation(); pcall(function() VIM:SendMouseButtonEvent(mp2.X,mp2.Y,0,false,game,1) end); trigPressed=false; lastRel=tick() end)
end)

