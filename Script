local function makeToggle(name,cb,page)
    page=page or miscPage
    local row=make("TextButton",{Size=UDim2.new(1,0,0,30),BackgroundColor3=C.bg2,BorderSizePixel=0,Text=""},page)
    corner(row,6); local rS=stroke(row,C.border,1)
    make("TextLabel",{Text=name,Size=UDim2.new(1,-46,1,0),Position=UDim2.new(0,10,0,0),
        BackgroundTransparency=1,TextColor3=C.text,TextSize=11,Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Left},row)
    local dot=make("Frame",{Size=UDim2.new(0,9,0,9),Position=UDim2.new(1,-18,0.5,-4),
        BackgroundColor3=C.off,BorderSizePixel=0},row)
    corner(dot,9)
    toggleStates[name]=false
    local function setState(on)
        toggleStates[name]=on
        dot.BackgroundColor3=on and C.on or C.off
        row.BackgroundColor3=on and C.bg3 or C.bg2
        rS.Color=on and C.borderOn or C.border
    end
    row.MouseButton1Click:Connect(function() setState(not toggleStates[name]); cb(toggleStates[name]) end)
    return setState
end

local function makeSlider(name,minV,maxV,defV,suffix,cb,page)
    page=page or miscPage; suffix=suffix or ""
    local f=make("Frame",{Size=UDim2.new(1,0,0,46),BackgroundColor3=C.bg2,BorderSizePixel=0},page)
    corner(f,6); stroke(f,C.border,1)
    local cv=defV
    local vL=make("TextLabel",{Text=name..":  "..cv..suffix,Size=UDim2.new(1,-16,0,18),
        Position=UDim2.new(0,8,0,4),BackgroundTransparency=1,TextColor3=C.text,
        TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left},f)
    local track=make("Frame",{Size=UDim2.new(1,-16,0,4),Position=UDim2.new(0,8,0,30),
        BackgroundColor3=C.bg3,BorderSizePixel=0},f)
    corner(track,9)
    local fill=make("Frame",{Size=UDim2.new((defV-minV)/(maxV-minV),0,1,0),
        BackgroundColor3=C.accent,BorderSizePixel=0},track)
    corner(fill,9)
    local drag=false
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    RunService.RenderStepped:Connect(function()
        if not drag then return end
        local mp=UserInputService:GetMouseLocation()
        local r=math.clamp((mp.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        cv=math.floor(minV+r*(maxV-minV))
        fill.Size=UDim2.new(r,0,1,0); vL.Text=name..":  "..cv..suffix; cb(cv)
    end)
    return f,function(v) -- setter
        local r=(v-minV)/(maxV-minV)
        cv=v; fill.Size=UDim2.new(r,0,1,0); vL.Text=name..":  "..cv..suffix
    end
end

