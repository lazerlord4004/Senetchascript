-- ══════════════════════════════════════════════════════
--  SILENT AIM
--  We intercept mouse clicks (LMB) while silent aim is
--  active and a target is locked. At the moment of the
--  click we snap the camera to face the target's head,
--  wait one RenderStepped (so Roblox's tool raycast runs
--  against the redirected angle), then restore. The view
--  shift is ~1 frame and completely invisible in-game.
-- ══════════════════════════════════════════════════════

local silentAimWasHeld = false  -- separate variable, was incorrectly sharing aimbotWasHeld

-- Camera redirect happens on LMB down, which is when tools fire
UserInputService.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    if not silentAimActive then return end
    if not silentAimTarget or not silentAimTarget.Character then return end
    -- Only redirect if a tool is equipped
    local tool = character and character:FindFirstChildOfClass("Tool")
    if not tool then return end

    local hw = getHeadWorld(silentAimTarget)
    if not hw then return end

    local savedCF = camera.CFrame
    camera.CFrame  = CFrame.new(savedCF.Position, hw)

    -- Restore the very next rendered frame so player never notices
    local conn
    conn = RunService.RenderStepped:Connect(function()
        camera.CFrame = savedCF
        conn:Disconnect()
    end)
end)

-- Silent aim target selection loop
RunService.RenderStepped:Connect(function()
    if not silentAimActive then
        if silentAimTarget then silentAimTarget=nil; updateAllESPColors() end
        silentAimWasHeld=false; silentAimLocked=false; return
    end
    local held = isKeyHeld(silentAimKeybind)
    local jp   = held and not silentAimWasHeld

    if silentAimSticky then
        if jp then
            if silentAimLocked then
                silentAimLocked=false; silentAimTarget=nil; updateAllESPColors()
            else
                silentAimTarget=getNearestEnemy()
                silentAimLocked=silentAimTarget~=nil
                updateAllESPColors()
            end
        end
        if silentAimLocked and not targetAlive(silentAimTarget) then
            silentAimTarget=nil; silentAimLocked=false; updateAllESPColors()
        end
    else
        if held then
            local t=getNearestEnemy()
            if t~=silentAimTarget then silentAimTarget=t; updateAllESPColors() end
        else
            if silentAimTarget then silentAimTarget=nil; updateAllESPColors() end
        end
    end
    silentAimWasHeld = held
end)

