-- ============================================================
-- SILENT AIM
-- The hook is kept dead simple — just reads silentTarget which
-- the RenderStepped loop below keeps updated every frame.
-- No target search inside the hook (too slow, can error).
-- ============================================================
local function getSilentPart()
    if not silentTarget or not silentTarget.Character then return nil end
    local char = silentTarget.Character
    if aimBone == "Head" then
        return char:FindFirstChild("Head")
            or char:FindFirstChild("HumanoidRootPart")
    else
        return char:FindFirstChild("UpperTorso")
            or char:FindFirstChild("Torso")
            or char:FindFirstChild("HumanoidRootPart")
    end
end

-- Try hookmetamethod first (Synapse X, KRNL, etc.)
local hookedOk = pcall(function()
    local orig
    orig = hookmetamethod(game, "__index", newcclosure(function(self, key)
        if silentOn and silentTarget then
            if typeof(self) == "Instance" and self:IsA("Mouse") then
                if key == "Hit" or key == "Target" then
                    local part = getSilentPart()
                    if part then
                        local hit = part.CFrame + (part.Velocity * Vector3.new(1,0.1,1) * SILENT_PRED)
                        return key == "Hit" and hit or part
                    end
                end
            end
        end
        return orig(self, key)
    end))
end)

-- Fallback: getrawmetatable (Script-Ware, Fluxus, etc.)
if not hookedOk then
    pcall(function()
        local mt  = getrawmetatable(game)
        local ro  = pcall(setreadonly, mt, false) -- some executors use makewriteable
        if not ro then pcall(makewriteable, mt) end
        local oi  = mt.__index
        mt.__index = newcclosure(function(self, key)
            if silentOn and silentTarget then
                if self == silentMouse and (key == "Hit" or key == "Target") then
                    local part = getSilentPart()
                    if part then
                        local hit = part.CFrame + (part.Velocity * Vector3.new(1,0.1,1) * SILENT_PRED)
                        return key == "Hit" and hit or part
                    end
                end
            end
            return oi(self, key)
        end)
        pcall(setreadonly, mt, true)
    end)
end

RunService.RenderStepped:Connect(function()
    if not silentOn then
        silentTarget=nil; silentHeld=false; silentLocked=false; return
    end
    local h = held(silentKB)
    local jp = h and not silentHeld
    if silentSticky then
        -- Toggle: press once to lock target, press again to unlock
        if jp then
            if silentLocked then
                silentLocked=false; silentTarget=nil
            else
                silentTarget=nearest(LEGIT_FOV)
                silentLocked=silentTarget~=nil
            end
        end
        -- Drop dead targets
        if silentLocked and not isAlive(silentTarget) then
            silentTarget=nil; silentLocked=false
        end
    else
        -- Hold: update target every frame while key held
        if h then
            silentTarget = nearest(LEGIT_FOV)
        else
            silentTarget = nil
        end
    end
    silentHeld = h
end)

