    elseif trigSticky then local h=held(trigKB); local jp=h and not trigHeld; if jp then trigLocked=not trigLocked end; trigHeld=h; shouldFire=trigLocked
    else local h=held(trigKB); trigHeld=h; shouldFire=h end
    if not shouldFire then return end
    local now=tick(); if now-lastShot<TRIG_PRESS then return end
    local tool=character and character:FindFirstChildOfClass("Tool"); if not tool then return end
    local mp=UserInputService:GetMouseLocation()
    local ur=camera:ScreenPointToRay(mp.X,mp.Y); local rp=RaycastParams.new(); rp.FilterDescendantsInstances={player.Character}; rp.FilterType=Enum.RaycastFilterType.Exclude
