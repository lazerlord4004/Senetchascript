-- Dragging (title bar only)
do
    local drag,ds,dp = false,Vector2.zero,nil
    -- Use a full-screen invisible frame to capture drag even when mouse leaves title bar
    local dragCapture = Instance.new("Frame")
    dragCapture.Size = UDim2.new(1,0,1,0)
    dragCapture.BackgroundTransparency = 1
    dragCapture.ZIndex = 100
    dragCapture.Visible = false
    dragCapture.Parent = screenGui

    titleBar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true
            ds   = Vector2.new(inp.Position.X, inp.Position.Y)
            dp   = mainFrame.Position
            dragCapture.Visible = true
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = false
            dragCapture.Visible = false
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if drag and inp.UserInputType == Enum.UserInputType.MouseMove then
            local pos = UserInputService:GetMouseLocation()
            local d   = pos - ds
            mainFrame.Position = UDim2.new(
                dp.X.Scale, dp.X.Offset + d.X,
                dp.Y.Scale, dp.Y.Offset + d.Y
            )
        end
    end)
end

