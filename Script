RunService.Heartbeat:Connect(function()
    if not trigOn then
        if trigPressed then local mp=UserInputService:GetMouseLocation(); pcall(function() VIM:SendMouseButtonEvent(mp.X,mp.Y,0,false,game,1) end); trigPressed=false end
        return
    end
    local shouldFire=false
