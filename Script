RunService.RenderStepped:Connect(function()
    if not rageAimActive then
        if rageAimTarget then rageAimTarget=nil; updateAllESPColors() end
        rageWasHeld=false; rageAimLocked=false; return
    end
    local held=isKeyHeld(rageKeybind)
