local function flingPlayer(target)
    if not target.Character then return end
    local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
    local mHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not tHrp or not mHrp then return end

    task.spawn(function()
        -- Step 1: teleport our character directly on top of the target
        mHrp.CFrame = tHrp.CFrame

        -- Step 2: weld ourselves to the target so we spin together
        local weld = Instance.new("ManualWeld")
        weld.Part0 = mHrp
        weld.Part1 = tHrp
        weld.C0    = CFrame.new(0, 0, 0)
        weld.Parent = mHrp

        -- Step 3: spin OUR root part insanely fast — because we're welded,
        -- the target gets dragged and flung when the weld breaks
        local bav = Instance.new("BodyAngularVelocity")
        bav.AngularVelocity = Vector3.new(0, 800, 0)
        bav.MaxTorque       = Vector3.new(math.huge, math.huge, math.huge)
        bav.P               = math.huge
        bav.Parent          = mHrp

        -- Step 4: after a short spin, blast them upward and sideways
        task.wait(0.18)
        weld:Destroy()
        bav:Destroy()

        local bv = Instance.new("BodyVelocity")
        bv.Velocity  = Vector3.new(
            math.random(-1,1) * 500,
            600,
            math.random(-1,1) * 500
        )
        bv.MaxForce  = Vector3.new(math.huge, math.huge, math.huge)
        bv.P         = math.huge
        bv.Parent    = tHrp
        task.wait(0.1)
        bv:Destroy()
    end)
end

local function teleportToPlayer(target)
    if not target.Character then return end
    local tHrp=target.Character:FindFirstChild("HumanoidRootPart")
    local mHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if tHrp and mHrp then mHrp.CFrame=tHrp.CFrame+Vector3.new(2,0,0) end
end

local plRows={}

local function buildPlayerRow(target)
    if plRows[target] then return end
    local row=newInstance("Frame",{Size=UDim2.new(1,0,0,48),BackgroundColor3=Color3.fromRGB(17,13,33),BorderSizePixel=0},playersPage)
    corner(row,8); stroke(row,Color3.fromRGB(55,36,100),1)

    newInstance("TextLabel",{Text="👤",Size=UDim2.new(0,28,1,0),Position=UDim2.new(0,6,0,0),
        BackgroundTransparency=1,TextColor3=Color3.fromRGB(175,135,220),TextSize=18,Font=Enum.Font.Gotham},row)

    newInstance("TextLabel",{Text=target.Name,Size=UDim2.new(1,-220,1,0),Position=UDim2.new(0,36,0,0),
        BackgroundTransparency=1,TextColor3=Color3.fromRGB(220,210,245),TextSize=13,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd},row)

    local function aBtn(label,color,xOff)
        local b=newInstance("TextButton",{Text=label,Size=UDim2.new(0,60,0,28),Position=UDim2.new(1,xOff,0.5,-14),
            BackgroundColor3=color,TextColor3=Color3.fromRGB(255,255,255),TextSize=10,Font=Enum.Font.GothamBold,BorderSizePixel=0},row)
        corner(b,5); return b
    end

    local specBtn=aBtn("Spectate",Color3.fromRGB(48,105,195),-204)
    local tpBtn  =aBtn("Teleport",Color3.fromRGB(38,135,75), -140)
    local flBtn  =aBtn("Fling",   Color3.fromRGB(185,48,58), -76)

    specBtn.Name="SpecBtn"
    specBtn.MouseButton1Click:Connect(function()
        if spectating==target then
            stopSpectate(); specBtn.Text="Spectate"; specBtn.BackgroundColor3=Color3.fromRGB(48,105,195)
        else
            startSpectate(target); specBtn.Text="■ Stop"; specBtn.BackgroundColor3=Color3.fromRGB(115,58,18)
            for p2,r2 in pairs(plRows) do
                if p2~=target then local sb=r2:FindFirstChild("SpecBtn")
                    if sb then sb.Text="Spectate"; sb.BackgroundColor3=Color3.fromRGB(48,105,195) end end
            end
        end
    end)
    tpBtn.MouseButton1Click:Connect(function() teleportToPlayer(target) end)
    flBtn.MouseButton1Click:Connect(function() flingPlayer(target) end)
    plRows[target]=row
end

local function removePlayerRow(target)
    if plRows[target] then plRows[target]:Destroy(); plRows[target]=nil end
end

for _,p in pairs(Players:GetPlayers()) do if p~=player then buildPlayerRow(p) end end
Players.PlayerAdded:Connect(function(p) task.wait(0.5); buildPlayerRow(p) end)
Players.PlayerRemoving:Connect(function(p)
    if spectating==p then stopSpectate() end
    removePlayerRow(p)
end)

