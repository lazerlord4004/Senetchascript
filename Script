-- ================================================================
--  ESP  (Drawing API — boxes stay square regardless of angle)
-- ================================================================
local function getESPColor(p)
    local locked=(aimbotActive and aimbotTarget==p)or(silentAimActive and silentAimTarget==p)
    return locked and Color3.fromRGB(220,40,40) or Color3.fromRGB(255,255,255)
end

local function newLine(thickness,color,zindex)
    local l=Drawing.new("Line")
    l.Visible=false; l.Color=color or Color3.new(1,1,1)
    l.Thickness=thickness or 1.5; l.Transparency=1
    l.ZIndex=zindex or 5
    return l
end

local function newText()
    local t=Drawing.new("Text")
    t.Visible=false; t.Color=Color3.new(1,1,1)
    t.Size=13; t.Font=Drawing.Fonts.UI
    t.Outline=true; t.OutlineColor=Color3.new(0,0,0)
    t.Center=true; t.ZIndex=6
    return t
end

local function createESP(p)
    if not p.Character or ESP_OBJECTS[p] then return end
    local hrp=p.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    -- 4 box lines
    local box={newLine(1.5),newLine(1.5),newLine(1.5),newLine(1.5)}
    -- hp: background + fill (vertical lines to the left of box)
    local hpBg   = newLine(4, Color3.fromRGB(25,20,40), 4)
    local hpFill = newLine(3, Color3.fromRGB(60,220,90), 5)
    -- name
    local nameTag = newText()
    nameTag.Text = p.Name

    ESP_OBJECTS[p]={box=box,hpBg=hpBg,hpFill=hpFill,nameTag=nameTag,char=p.Character}
end

local function removeESP(p)
    local o=ESP_OBJECTS[p]; if not o then return end
    for _,l in ipairs(o.box) do pcall(function() l:Remove() end) end
    pcall(function() o.hpBg:Remove() end)
    pcall(function() o.hpFill:Remove() end)
    pcall(function() o.nameTag:Remove() end)
    ESP_OBJECTS[p]=nil
end

local function updateAllESPColors()
    for p,o in pairs(ESP_OBJECTS) do
        local col=getESPColor(p)
        for _,l in ipairs(o.box) do l.Color=col end
        o.nameTag.Color=col
    end
end

local function enableESP()
