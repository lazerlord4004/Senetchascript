local function fling(target)
    if not target.Character then return end
    local tHrp=target.Character:FindFirstChild("HumanoidRootPart"); local mHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart"); if not tHrp or not mHrp then return end
    task.spawn(function()
        mHrp.CFrame=tHrp.CFrame
        for _,p in ipairs(player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
        local bav=Instance.new("BodyAngularVelocity"); bav.AngularVelocity=Vector3.new(0,9999,0); bav.MaxTorque=Vector3.new(0,math.huge,0); bav.P=math.huge; bav.Parent=mHrp
        local i=0; local dirs={Vector3.new(1,2.5,1),Vector3.new(-1,2.5,-1),Vector3.new(1,2.5,-1),Vector3.new(-1,2.5,1)}
        local conn=RunService.Heartbeat:Connect(function() if not tHrp or not tHrp.Parent then return end; i=(i%#dirs)+1; local bv=Instance.new("BodyVelocity"); bv.Velocity=dirs[i]*800; bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge); bv.P=math.huge; bv.Parent=tHrp; Debris:AddItem(bv,0.05) end)
        task.wait(0.2); conn:Disconnect(); bav:Destroy()
        if tHrp and tHrp.Parent then local bv=Instance.new("BodyVelocity"); bv.Velocity=Vector3.new(math.random(-300,300),900,math.random(-300,300)); bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge); bv.P=math.huge; bv.Parent=tHrp; Debris:AddItem(bv,0.15) end
        task.wait(0.3); for _,p in ipairs(player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=true end end
    end)
end
