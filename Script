UserInputService.InputBegan:Connect(function(inp, gpe)
    if not listeningForKey then return end
    if inp.KeyCode == Enum.KeyCode.Escape then closeKeybindCapture() return end
    local label, key
    if inp.UserInputType == Enum.UserInputType.Keyboard then
        label = inp.KeyCode.Name; key = inp.KeyCode
    elseif inp.UserInputType == Enum.UserInputType.MouseButton1 then
        label = "LMB"; key = Enum.UserInputType.MouseButton1
    elseif inp.UserInputType == Enum.UserInputType.MouseButton2 then
        label = "RMB"; key = Enum.UserInputType.MouseButton2
    else return end
    closeKeybindCapture()
    if kbCallback then kbCallback(key, label) end
end)

