    -- Button row (6 buttons across the bottom)
    local function aBtn(label,col,idx)
        -- evenly spaced across width
        local btnW=56; local gap=4; local totalW=(btnW*6)+(gap*5); local startX=math.floor((400-totalW)/2)
        local b=make("TextButton",{Text=label,Size=UDim2.new(0,btnW,0,24),Position=UDim2.new(0,startX+(idx-1)*(btnW+gap),0,40),BackgroundColor3=col,TextColor3=C.textBright,TextSize=9,Font=Enum.Font.GothamBold,BorderSizePixel=0},row); corner(b,5); return b
    end

