local spectating=nil; local spectateConn=nil

local function stopSpectate()
    if spectateConn then spectateConn:Disconnect(); spectateConn=nil end
    spectating=nil
    camera.CameraType=Enum.CameraType.Custom
    local c=player.Character; if c then camera.CameraSubject=c:FindFirstChildOfClass("Humanoid") end
end

local function startSpectate(target)
    stopSpectate(); if not target.Character then return end
    spectating=target; camera.CameraType=Enum.CameraType.Follow
    camera.CameraSubject=target.Character:FindFirstChildOfClass("Humanoid")
    spectateConn=target.CharacterAdded:Connect(function(char)
        task.wait(1); camera.CameraSubject=char:FindFirstChildOfClass("Humanoid")
    end)
end

local function flingPlayer(target)
    if not target.Character then return end
    local tHrp=target.Character:FindFirstChild("HumanoidRootPart")
    local mHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not tHrp or not mHrp then return end
    task.spawn(function()
        mHrp.CFrame=tHrp.CFrame
        for _,part in ipairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide=false end
        end
        local myBav=Instance.new("BodyAngularVelocity")
        myBav.AngularVelocity=Vector3.new(0,9999,0)
        myBav.MaxTorque=Vector3.new(0,math.huge,0)
        myBav.P=math.huge; myBav.Parent=mHrp
        local elapsed=0
        local dirs={Vector3.new(1,2.5,1),Vector3.new(-1,2.5,-1),Vector3.new(1,2.5,-1),Vector3.new(-1,2.5,1)}
        local i=0
        local conn=RunService.Heartbeat:Connect(function(dt)
            elapsed=elapsed+dt; if not tHrp or not tHrp.Parent then return end
            i=(i%#dirs)+1
            local bv=Instance.new("BodyVelocity"); bv.Velocity=dirs[i]*800
            bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge); bv.P=math.huge; bv.Parent=tHrp
            Debris:AddItem(bv,0.05)
        end)
        task.wait(0.2); conn:Disconnect(); myBav:Destroy()
        if tHrp and tHrp.Parent then
            local bv=Instance.new("BodyVelocity")
            bv.Velocity=Vector3.new(math.random(-300,300),900,math.random(-300,300))
            bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge); bv.P=math.huge; bv.Parent=tHrp
            Debris:AddItem(bv,0.15)
        end
        task.wait(0.3)
        for _,part in ipairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide=true end
        end
    end)
end

local function teleportTo(target)
    if not target.Character then return end
    local tHrp=target.Character:FindFirstChild("HumanoidRootPart")
    local mHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if tHrp and mHrp then mHrp.CFrame=tHrp.CFrame+Vector3.new(2,0,0) end
end

local plRows={}
local orbitBtnMap={}  -- [player] = orbitBtn

local function buildPlayerRow(target)
    if plRows[target] then return end
    local row=make("Frame",{Size=UDim2.new(1,0,0,44),BackgroundColor3=C.bg2,BorderSizePixel=0},plPage)
    corner(row,7); stroke(row,C.border,1)
    make("TextLabel",{Text=target.Name,Size=UDim2.new(1,-270,1,0),Position=UDim2.new(0,10,0,0),
        BackgroundTransparency=1,TextColor3=C.text,TextSize=12,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd},row)
    local function aBtn(label,col,xOff)
        local b=make("TextButton",{Text=label,Size=UDim2.new(0,56,0,26),Position=UDim2.new(1,xOff,0.5,-13),
            BackgroundColor3=col,TextColor3=C.textBright,TextSize=10,Font=Enum.Font.GothamBold,BorderSizePixel=0},row)
        corner(b,5); return b
    end
    local orbitBtn=aBtn("Orbit",  Color3.fromRGB(80,50,160), -264)
    local specBtn =aBtn("Spectate",Color3.fromRGB(42,98,180),-204)
    local tpBtn   =aBtn("Teleport",Color3.fromRGB(32,128,65),-144)
    local flBtn   =aBtn("Fling",   C.red,                    -84)

    orbitBtn.Name="OrbitBtn"
    specBtn.Name="SpecBtn"

    orbitBtn.MouseButton1Click:Connect(function()
        if orbitActive and orbitTarget==target then
            stopOrbit()
            orbitBtn.Text="Orbit"; orbitBtn.BackgroundColor3=Color3.fromRGB(80,50,160)
            toggleStates["Orbit  (selected player)"]=false
        else
            -- Set the orbit target and start
            orbitTarget=target
            startOrbit(target)
            orbitBtn.Text="Stop"; orbitBtn.BackgroundColor3=C.red
            toggleStates["Orbit  (selected player)"]=true
            -- Reset other orbit buttons
            for p2,r2 in pairs(plRows) do
                if p2~=target then
                    local ob=r2:FindFirstChild("OrbitBtn")
                    if ob then ob.Text="Orbit"; ob.BackgroundColor3=Color3.fromRGB(80,50,160) end
                end
            end
        end
    end)
    specBtn.MouseButton1Click:Connect(function()
        if spectating==target then
            stopSpectate(); specBtn.Text="Spectate"; specBtn.BackgroundColor3=Color3.fromRGB(42,98,180)
        else
            startSpectate(target); specBtn.Text="Stop"; specBtn.BackgroundColor3=Color3.fromRGB(105,50,14)
            for p2,r2 in pairs(plRows) do
                if p2~=target then
                    local sb=r2:FindFirstChild("SpecBtn")
                    if sb then sb.Text="Spectate"; sb.BackgroundColor3=Color3.fromRGB(42,98,180) end
                end
            end
        end
    end)
    tpBtn.MouseButton1Click:Connect(function() teleportTo(target) end)
    flBtn.MouseButton1Click:Connect(function() flingPlayer(target) end)
    plRows[target]=row
end

local function removePlayerRow(target)
    if plRows[target] then plRows[target]:Destroy(); plRows[target]=nil end
end

for _,p in pairs(Players:GetPlayers()) do if p~=player then buildPlayerRow(p) end end
Players.PlayerAdded:Connect(function(p) task.wait(0.5); buildPlayerRow(p) end)
Players.PlayerRemoving:Connect(function(p)
    if spectating==p then stopSpectate() end
    if orbitTarget==p then stopOrbit() end
    removePlayerRow(p)
end)

