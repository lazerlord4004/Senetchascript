-- ══════════════════════════════════════════════════════
RunService.RenderStepped:Connect(function()
    if not aimbotActive then
        if aimbotTarget then aimbotTarget=nil; updateAllESPColors() end
        aimbotWasHeld=false; aimbotLocked=false; return
    end
    local held=isKeyHeld(aimbotKeybind); local jp=held and not aimbotWasHeld
    if aimbotSticky then
        if jp then
            if aimbotLocked then aimbotLocked=false; aimbotTarget=nil; updateAllESPColors()
            else aimbotTarget=getNearestEnemy(); aimbotLocked=aimbotTarget~=nil; updateAllESPColors() end
        end
        if aimbotLocked then
            if not targetAlive(aimbotTarget) then aimbotTarget=nil; aimbotLocked=false; updateAllESPColors()
            else
                local hw=getHeadWorld(aimbotTarget)
                if hw then local cf=camera.CFrame; camera.CFrame=cf:Lerp(CFrame.lookAt(cf.Position,hw),AIMBOT_SMOOTHING) end
            end
        end
    else
        if held then
            local t=getNearestEnemy(); if t~=aimbotTarget then aimbotTarget=t; updateAllESPColors() end
            if aimbotTarget then local hw=getHeadWorld(aimbotTarget); if hw then local cf=camera.CFrame; camera.CFrame=cf:Lerp(CFrame.lookAt(cf.Position,hw),AIMBOT_SMOOTHING) end end
        else
            if aimbotTarget then aimbotTarget=nil; updateAllESPColors() end
        end
    end
    aimbotWasHeld=held
end)

-- ══════════════════════════════════════════════════════
--  SILENT AIM  (fixed — no visible camera teleport)
--  Camera is snapped and restored within the SAME frame
--  so the player never sees any movement.
-- ══════════════════════════════════════════════════════
local silentCF=nil
local silentAimWasHeld=false   -- forward-declare used in loop below

local function doSilentRedirect()
    if not silentAimActive or not silentAimTarget then return end
    local hw=getHeadWorld(silentAimTarget); if not hw then return end
    silentCF=camera.CFrame
    camera.CFrame=CFrame.new(silentCF.Position, hw)
end

local function undoSilentRedirect()
    if silentCF then camera.CFrame=silentCF; silentCF=nil end
end

local function hookTool(tool)
    tool.Activated:Connect(function()
        doSilentRedirect()
        -- Restore before the very next rendered frame so the player sees nothing
        local conn; conn=RunService.RenderStepped:Connect(function()
            undoSilentRedirect(); conn:Disconnect()
        end)
    end)
end

local function hookCharacterTools(char)
    for _,child in pairs(char:GetChildren()) do if child:IsA("Tool") then hookTool(child) end end
    char.ChildAdded:Connect(function(child) if child:IsA("Tool") then hookTool(child) end end)
end

player.CharacterAdded:Connect(function(char)
    character=char; humanoid=char:WaitForChild("Humanoid"); rootPart=char:WaitForChild("HumanoidRootPart")
    hookCharacterTools(char)
end)
if player.Character then hookCharacterTools(player.Character) end

RunService.RenderStepped:Connect(function()
    if not silentAimActive then
        if silentAimTarget then silentAimTarget=nil; updateAllESPColors() end
        silentAimWasHeld=false; silentAimLocked=false; return
    end
    local held=isKeyHeld(silentAimKeybind); local jp=held and not silentAimWasHeld
    if silentAimSticky then
        if jp then
            if silentAimLocked then silentAimLocked=false; silentAimTarget=nil; updateAllESPColors()
            else silentAimTarget=getNearestEnemy(); silentAimLocked=silentAimTarget~=nil; updateAllESPColors() end
        end
        if silentAimLocked and not targetAlive(silentAimTarget) then
            silentAimTarget=nil; silentAimLocked=false; updateAllESPColors()
        end
    else
        if held then
            local t=getNearestEnemy(); if t~=silentAimTarget then silentAimTarget=t; updateAllESPColors() end
        else
            if silentAimTarget then silentAimTarget=nil; updateAllESPColors() end
        end
    end
    silentAimWasHeld=held
end)

