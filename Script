    }, row)

    local track = make("Frame", {
        Size = UDim2.new(0,28,0,14), Position = UDim2.new(1,-36,0.5,-7),
        BackgroundColor3 = C.off, BorderSizePixel = 0,
    }, row)
    corner(track, 7)

    local knob = make("Frame", {
        Size = UDim2.new(0,10,0,10), Position = UDim2.new(0,2,0.5,-5),
        BackgroundColor3 = Color3.fromRGB(170,165,190), BorderSizePixel = 0,
    }, track)
    corner(knob, 9)

    toggleStates[name] = false

    local function setState(on)
        toggleStates[name]    = on
        knob.Position         = on and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5)
        knob.BackgroundColor3 = on and Color3.fromRGB(255,255,255) or Color3.fromRGB(170,165,190)
        track.BackgroundColor3= on and C.accent or C.off
        row.BackgroundColor3  = on and C.bg3    or C.bg2
        rS.Color              = on and C.borderOn or C.border
    end

    row.MouseButton1Click:Connect(function()
        setState(not toggleStates[name]); cb(toggleStates[name])
    end)
    return setState
end

local function makeSlider(name, minV, maxV, defV, suffix, cb, page)
    page = page or miscPage; suffix = suffix or ""
    local f = make("Frame", {
        Size = UDim2.new(1,0,0,48), BackgroundColor3 = C.bg2, BorderSizePixel = 0,
    }, page)
    corner(f, 7)
    make("UIStroke", {Color=C.border, Thickness=1}, f)

    local cv = defV
    make("TextLabel", {
        Text = name, Size = UDim2.new(0.6,0,0,20), Position = UDim2.new(0,10,0,5),
        BackgroundTransparency=1, TextColor3=C.text, TextSize=11, Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Left,
    }, f)

    local vLbl = make("TextLabel", {
        Text = tostring(cv)..suffix,
        Size = UDim2.new(0.4,-10,0,20), Position = UDim2.new(0.6,0,0,5),
        BackgroundTransparency=1, TextColor3=C.accentBright,
        TextSize=11, Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Right,
    }, f)

    local track = make("Frame", {
        Size = UDim2.new(1,-20,0,4), Position = UDim2.new(0,10,0,32),
        BackgroundColor3 = Color3.fromRGB(28,22,50), BorderSizePixel=0,
    }, f)
    corner(track, 9)

    local fill = make("Frame", {
        Size = UDim2.new((defV-minV)/(maxV-minV),0,1,0),
        BackgroundColor3 = C.accent, BorderSizePixel=0,
    }, track)
    corner(fill, 9)

    local handle = make("Frame", {
        Size = UDim2.new(0,10,0,10), BackgroundColor3 = C.textBright, BorderSizePixel=0,
    }, track)
    corner(handle, 9)

    local function updateHandle(r)
        handle.Position = UDim2.new(r, -math.floor(10*r), 0.5, -5)
    end
    updateHandle((defV-minV)/(maxV-minV))

    local drag = false
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    RunService.RenderStepped:Connect(function()
        if not drag then return end
        local mp = UserInputService:GetMouseLocation()
        local r  = math.clamp((mp.X-track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
        cv = math.floor(minV + r*(maxV-minV))
        fill.Size  = UDim2.new(r,0,1,0)
        vLbl.Text  = tostring(cv)..suffix
        updateHandle(r)
        cb(cv)
    end)
end

