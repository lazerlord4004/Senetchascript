local function switchTab(name)
    for _,n in ipairs(TAB_NAMES) do
        if tabPages[n]  then tabPages[n].Visible=(n==name) end
        if tabBtns[n] then
            tabBtns[n].BackgroundColor3 = (n==name) and C.accent or Color3.fromRGB(0,0,0)
            tabBtns[n].BackgroundTransparency = (n==name) and 0 or 1
            tabBtns[n].TextColor3 = (n==name) and C.textBright or C.textDim
        end
    end
end

