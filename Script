-- Dropdown
local function makeDropdown(name, page)
    page = page or cheatsPage
    local isOpen = false
    local wrapper = make("Frame",{
        Size=UDim2.new(1,0,0,34),
        BackgroundTransparency=1,
        ClipsDescendants=true,
    },page)
    local wL = vlist(wrapper,3)

    local header = make("TextButton",{
        Size=UDim2.new(1,0,0,34),
        BackgroundColor3=C.bg2,
        BorderSizePixel=0, Text="",
        LayoutOrder=0,
    },wrapper)
    corner(header,7)
    local hS = uistroke(header,C.border,1)

    make("TextLabel",{
        Text=name, Size=UDim2.new(1,-40,1,0), Position=UDim2.new(0,10,0,0),
        BackgroundTransparency=1, TextColor3=C.text,
        TextSize=12, Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,
    },header)
    local arrow = make("TextLabel",{
        Text="v", Size=UDim2.new(0,20,1,0), Position=UDim2.new(1,-24,0,0),
        BackgroundTransparency=1, TextColor3=C.textDim,
        TextSize=11, Font=Enum.Font.GothamBold,
    },header)

    local inner = make("Frame",{
        Size=UDim2.new(1,0,0,0),
        BackgroundTransparency=1,
        LayoutOrder=1,
    },wrapper)
    local iL = vlist(inner,3)
    pad(inner,8,0,2,2)

    local function resize()
        local h = iL.AbsoluteContentSize.Y+4
        inner.Size   = UDim2.new(1,0,0,isOpen and h or 0)
        wrapper.Size = UDim2.new(1,0,0,isOpen and (34+3+h) or 34)
    end
    iL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(resize)
    header.MouseButton1Click:Connect(function()
        isOpen=not isOpen
        arrow.Text=isOpen and "^" or "v"
        hS.Color=isOpen and C.borderActive or C.border
        resize()
    end)
    return inner
end

