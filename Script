    local orbitBtn = aBtn("Orbit",     Color3.fromRGB(75,45,155),   2)
    local specBtn  = aBtn("Spectate",  Color3.fromRGB(40,95,175),   3)
    local tpBtn    = aBtn("Teleport",  Color3.fromRGB(30,125,65),   4)
    local flBtn    = aBtn("Fling",     Color3.fromRGB(160,60,20),   5)
    local copyBtn  = aBtn("Copy Name", Color3.fromRGB(55,50,90),    6)

    akBtn.Name="AKBtn"; orbitBtn.Name="OrbitBtn"; specBtn.Name="SpecBtn"

    -- Auto Kill
    akBtn.MouseButton1Click:Connect(function()
        if autoKillActive and autoKillTarget==target then
            stopAutoKill()
            akBtn.Text="Auto Kill"; akBtn.BackgroundColor3=Color3.fromRGB(180,35,55)
            toggleStates["Auto Kill"]=false
        else
            autoKillTarget=target
            startAutoKill(target)
            akBtn.Text="Stop AK"; akBtn.BackgroundColor3=C.red
            toggleStates["Auto Kill"]=true
            -- Reset other AK buttons
            for p2,r2 in pairs(plRows) do
                if p2~=target then
                    local ab=r2:FindFirstChild("AKBtn")
                    if ab then ab.Text="Auto Kill"; ab.BackgroundColor3=Color3.fromRGB(180,35,55) end
                end
            end
        end
    end)

    -- Orbit
    orbitBtn.MouseButton1Click:Connect(function()
        if orbitActive and orbitTarget==target then
            stopOrbit(); orbitBtn.Text="Orbit"; orbitBtn.BackgroundColor3=Color3.fromRGB(75,45,155)
        else
            orbitTarget=target; startOrbit(target)
            orbitBtn.Text="Stop"; orbitBtn.BackgroundColor3=C.red
            for p2,r2 in pairs(plRows) do if p2~=target then local ob=r2:FindFirstChild("OrbitBtn"); if ob then ob.Text="Orbit"; ob.BackgroundColor3=Color3.fromRGB(75,45,155) end end end
        end
    end)

    -- Spectate
    specBtn.MouseButton1Click:Connect(function()
        if spectating==target then
            stopSpectate(); specBtn.Text="Spectate"; specBtn.BackgroundColor3=Color3.fromRGB(40,95,175)
        else
            startSpectate(target); specBtn.Text="Stop"; specBtn.BackgroundColor3=Color3.fromRGB(105,50,14)
            for p2,r2 in pairs(plRows) do if p2~=target then local sb=r2:FindFirstChild("SpecBtn"); if sb then sb.Text="Spectate"; sb.BackgroundColor3=Color3.fromRGB(40,95,175) end end end
        end
    end)

    tpBtn.MouseButton1Click:Connect(function() teleportTo(target) end)
    flBtn.MouseButton1Click:Connect(function() flingPlayer(target) end)
    copyBtn.MouseButton1Click:Connect(function()
        -- Copy name to clipboard
        pcall(function() setclipboard(target.Name) end)
        copyBtn.Text="Copied!"; task.delay(1.5,function() copyBtn.Text="Copy Name" end)
    end)

    plRows[target]=row
end

