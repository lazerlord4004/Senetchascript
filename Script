local function makeScrollRow(name,minV,maxV,defV,suffix,cb,page)
    page=page or ragePage; suffix=suffix or ""
    local row=make("Frame",{Size=UDim2.new(1,0,0,30),BackgroundColor3=C.bg2,BorderSizePixel=0},page)
    corner(row,6); stroke(row,C.border,1)
    local cv=defV
    make("TextLabel",{Text=name,Size=UDim2.new(1,-140,1,0),Position=UDim2.new(0,10,0,0),
        BackgroundTransparency=1,TextColor3=C.text,TextSize=11,Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Left},row)
    local valLbl=make("TextLabel",{Text=tostring(cv)..suffix,Size=UDim2.new(0,60,1,0),
        Position=UDim2.new(1,-130,0,0),BackgroundTransparency=1,TextColor3=C.accentBright,
        TextSize=12,Font=Enum.Font.GothamBold},row)
    local decBtn=make("TextButton",{Text="-",Size=UDim2.new(0,28,0,22),Position=UDim2.new(1,-66,0.5,-11),
        BackgroundColor3=C.bg3,TextColor3=C.text,TextSize=14,Font=Enum.Font.GothamBold,BorderSizePixel=0},row)
    corner(decBtn,5)
    local incBtn=make("TextButton",{Text="+",Size=UDim2.new(0,28,0,22),Position=UDim2.new(1,-34,0.5,-11),
        BackgroundColor3=C.bg3,TextColor3=C.text,TextSize=14,Font=Enum.Font.GothamBold,BorderSizePixel=0},row)
    corner(incBtn,5)
    local step=(maxV-minV)/20
    local function update(v)
        cv=math.clamp(v,minV,maxV)
        valLbl.Text=string.format("%.1f",cv)..suffix; cb(cv)
    end
    -- Scroll wheel support
    row.MouseWheelForward:Connect(function()  update(cv+step) end)
    row.MouseWheelBackward:Connect(function() update(cv-step) end)
    decBtn.MouseButton1Click:Connect(function() update(cv-step) end)
    incBtn.MouseButton1Click:Connect(function() update(cv+step) end)
    return row
end

