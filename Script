local function openKB(label, cb)
    kbSub.Text    = "for:  " .. label
    kbCb          = cb
    kbGui.Enabled = true
    listeningForKey = false
    task.wait()
    listeningForKey = true
end

local function closeKB()
    listeningForKey = false
    kbGui.Enabled   = false
    kbCb            = nil
end

kbCancel.MouseButton1Click:Connect(closeKB)

UserInputService.InputBegan:Connect(function(inp, gpe)
    if not listeningForKey then return end
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then return end
    if inp.KeyCode == Enum.KeyCode.Escape then closeKB(); return end
    local bl, bk
    if inp.UserInputType == Enum.UserInputType.Keyboard then
        if inp.KeyCode == Enum.KeyCode.Unknown then return end
        bl = inp.KeyCode.Name; bk = inp.KeyCode
    elseif inp.UserInputType == Enum.UserInputType.MouseButton2 then
        bl = "RMB"; bk = Enum.UserInputType.MouseButton2
    elseif inp.UserInputType == Enum.UserInputType.MouseButton3 then
        bl = "MMB"; bk = Enum.UserInputType.MouseButton3
    elseif inp.UserInputType == Enum.UserInputType.MouseXButton1 then
        bl = "MB4"; bk = Enum.UserInputType.MouseXButton1
    elseif inp.UserInputType == Enum.UserInputType.MouseXButton2 then
        bl = "MB5"; bk = Enum.UserInputType.MouseXButton2
    else return end
    local saved = kbCb; closeKB(); if saved then saved(bk, bl) end
end)

