local keybindCallback = nil
local listeningForKey = false

local function openKeybindCapture(featureName, cb)
    kbSub.Text = "Setting keybind for: "..featureName
    keybindCallback = cb
    listeningForKey = true
    keybindOverlay.Visible = true
end
local function closeKeybindCapture()
    listeningForKey = false
    keybindOverlay.Visible = false
    keybindCallback = nil
end
kbCancel.MouseButton1Click:Connect(closeKeybindCapture)

UserInputService.InputBegan:Connect(function(input, gpe)
    if not listeningForKey then return end
    if input.KeyCode == Enum.KeyCode.Escape then closeKeybindCapture() return end
    local label, key
    if input.UserInputType == Enum.UserInputType.Keyboard then
        label = input.KeyCode.Name; key = input.KeyCode
    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
        label="LMB"; key=Enum.UserInputType.MouseButton1
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
        label="RMB"; key=Enum.UserInputType.MouseButton2
    else return end
    closeKeybindCapture()
    if keybindCallback then keybindCallback(key, label) end
end)

